<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>page.codeberg.andresmessina.Scriptura</id>

  <name>Scriptura</name>
  <summary>Read and study the Bible in depth</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="page.codeberg.andresmessina">
    <name>Andres Messina</name>
  </developer>

  <description>
    <p>
      Scriptura is a focused Bible study application for the Linux
      desktop. A calm, two-pane reading view sits at its center, with a
      full study library never more than a click away.
    </p>
    <p>It brings together:</p>
    <ul>
      <li>Side-by-side reading of two translations with synchronized scrolling, plus a distraction-free reading mode.</li>
      <li>Original-language word study — click any word for its Hebrew or Greek root, its grammar, and every other place it appears.</li>
      <li>A database of 340,000 cross-references linking related passages.</li>
      <li>Highlights, notes, and topical tags, all gathered into one searchable study journal.</li>
      <li>Full-text search across any installed text, and reading plans that track your progress day by day.</li>
      <li>A large, installable library of modern and classic Bibles, commentaries, devotionals, and reference works.</li>
    </ul>
    <p>
      Everything is stored on your computer with no telemetry. Scriptura
      connects to the network only to download the texts and reference
      data you choose.
    </p>
  </description>

  <launchable type="desktop-id">page.codeberg.andresmessina.Scriptura.desktop</launchable>

  <branding>
    <color type="primary" scheme_preference="light">#8B6520</color>
    <color type="primary" scheme_preference="dark">#C49B35</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://codeberg.org/andresmessina/scriptura/raw/branch/main/data/screenshots/01-two-pane-lexicon.png</image>
      <caption>Two-pane reading with the Strong's lexicon open on a Greek word</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/andresmessina/scriptura/raw/branch/main/data/screenshots/02-historical-commentaries.png</image>
      <caption>The Historical Commentaries pane — the church's voices on a verse, across the centuries</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/andresmessina/scriptura/raw/branch/main/data/screenshots/03-study-journal.png</image>
      <caption>Study Journal — every annotation in one filterable surface</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/andresmessina/scriptura/raw/branch/main/data/screenshots/04-reading-plan.png</image>
      <caption>Built-in reading plans with day-by-day progress</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/andresmessina/scriptura/raw/branch/main/data/screenshots/05-reading-mode-dark.png</image>
      <caption>F11 reading mode hides all chrome for distraction-free reading</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://codeberg.org/andresmessina/scriptura</url>
  <url type="bugtracker">https://codeberg.org/andresmessina/scriptura/issues</url>
  <url type="vcs-browser">https://codeberg.org/andresmessina/scriptura</url>
  <url type="contribute">https://codeberg.org/andresmessina/scriptura</url>
  <url type="donation">https://ko-fi.com/andresmessina</url>

  <categories>
    <category>Education</category>
    <category>Literature</category>
  </categories>

  <keywords>
    <keyword>Bible</keyword>
    <keyword>Scripture</keyword>
    <keyword>Study</keyword>
    <keyword>SWORD</keyword>
    <keyword>Lexicon</keyword>
    <keyword translate="no">Strong's</keyword>
    <keyword>Devotional</keyword>
    <keyword>Commentary</keyword>
  </keywords>

  <!--
    <provides>, <requires>, <recommends>, <supports> blocks deliberately
    omitted for now. appstreamcli compose (run during Flatpak build)
    rejects them on some configurations and the error message
    ('file-read-error') doesn't point at the specific block. Once the
    build is green, we can re-add these one at a time to identify
    which one compose objects to.
  -->

  <!--
    Content rating: the app itself generates no content. It displays
    user-installed third-party scripture / commentary modules.
    Following the convention of other Bible apps on Flathub
    (BibleTime, Yetzirah), rate as "none" across the board.
  -->
  <content_rating type="oars-1.1">
    <content_attribute id="violence-cartoon">none</content_attribute>
    <content_attribute id="violence-fantasy">none</content_attribute>
    <content_attribute id="violence-realistic">none</content_attribute>
    <content_attribute id="violence-bloodshed">none</content_attribute>
    <content_attribute id="violence-sexual">none</content_attribute>
    <content_attribute id="violence-desecration">none</content_attribute>
    <content_attribute id="violence-slavery">none</content_attribute>
    <content_attribute id="violence-worship">none</content_attribute>
    <content_attribute id="drugs-alcohol">none</content_attribute>
    <content_attribute id="drugs-narcotics">none</content_attribute>
    <content_attribute id="drugs-tobacco">none</content_attribute>
    <content_attribute id="sex-nudity">none</content_attribute>
    <content_attribute id="sex-themes">none</content_attribute>
    <content_attribute id="sex-homosexuality">none</content_attribute>
    <content_attribute id="sex-prostitution">none</content_attribute>
    <content_attribute id="sex-adultery">none</content_attribute>
    <content_attribute id="sex-appearance">none</content_attribute>
    <content_attribute id="language-profanity">none</content_attribute>
    <content_attribute id="language-humor">none</content_attribute>
    <content_attribute id="language-discrimination">none</content_attribute>
    <content_attribute id="social-chat">none</content_attribute>
    <content_attribute id="social-info">none</content_attribute>
    <content_attribute id="social-audio">none</content_attribute>
    <content_attribute id="social-location">none</content_attribute>
    <content_attribute id="social-contacts">none</content_attribute>
    <content_attribute id="money-purchasing">none</content_attribute>
    <content_attribute id="money-gambling">none</content_attribute>
  </content_rating>

  <releases>
    <release version="1.2.0" date="2026-07-05">
      <description>
        <p>Getting started, made discoverable.</p>
        <ul>
          <li>A new Tips &amp; Gestures guide, reachable from the menu, gathers every reading gesture in one place.</li>
          <li>Gentle one-time tips point out hidden gestures — like tapping a verse for its cross-references — the first time each is useful, then never again. You can turn them off any time.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2026-06-28">
      <description>
        <p>Customizable reading appearance.</p>
        <ul>
          <li>New Appearance panel: pick a reading paper — Paper, White, Sepia, Green, or a custom colour — with text colour that adapts to the page (a warm ink on sepia, and so on).</li>
          <li>Bold and justified text move to compact controls beside the font, and the menu's sections gain a clearer, calmer layout.</li>
          <li>Redesigned reading plans with a Today view and a month calendar of your progress.</li>
          <li>Fixed faint text trails when scrolling the reading view under Flatpak.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.1" date="2026-05-28">
      <description>
        <p>Packaging fixes.</p>
        <ul>
          <li>Convert the build to meson for a cleaner Flatpak install.</li>
          <li>Patch SWORD's CMake to properly link libcurl (upstream bug API-263).</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-05-23">
      <description>
        <p>
          Scriptura's first release. Read two translations side by side,
          study the original Hebrew and Greek behind any word, follow
          cross-references between passages, and keep your highlights and
          notes together in one searchable place — all on your own
          computer, offline.
        </p>
      </description>
    </release>
  </releases>
</component>
