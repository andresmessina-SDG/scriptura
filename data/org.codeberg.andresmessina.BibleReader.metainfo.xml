<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.codeberg.andresmessina.BibleReader</id>

  <name>Bible Reader</name>
  <summary>GNOME-native Bible study with SWORD modules and Strong's lexicon</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="org.codeberg.andresmessina">
    <name>Andres Messina</name>
  </developer>

  <description>
    <p>
      Bible Reader is a focused, native Linux Bible study application
      that pairs a quiet two-pane reading layout with the depth of
      SWORD Project modules.
    </p>
    <p>Features:</p>
    <ul>
      <li>Two independent panes — read two translations side by side, with per-pane sync locks.</li>
      <li>Strong's lexicon — click any Hebrew or Greek word for the original lexeme, morphology, and a word study across the book.</li>
      <li>Per-verse annotations — four highlight colors, underlines, notes with topical tags; all in-place edits with no scroll jumps.</li>
      <li>Cross-references — OpenBible.info's 340,000-reference database with a TSK fallback.</li>
      <li>Full-text search — Whoosh-backed per-module index with a canon distribution chart and case-sensitive option.</li>
      <li>Study Journal — master-detail browser for every annotation across every module, with tag management.</li>
      <li>Reading plans — six built-in plans with day-by-day progress tracking.</li>
      <li>Devotionals — Spurgeon's Morning and Evening and others with multi-section detection.</li>
      <li>Generic Books — Didache, Westminster Confession, Apostolic Fathers, and other tree-keyed reference works with a table-of-contents browser.</li>
      <li>eBible.org translations — modern licensed Bibles (LEB, BSB, etc.) not packaged for SWORD.</li>
      <li>F11 distraction-free reading mode.</li>
    </ul>
    <p>
      All data is stored locally. No telemetry. Network access only for
      downloading modules and reference data that you explicitly request.
    </p>
  </description>

  <launchable type="desktop-id">org.codeberg.andresmessina.BibleReader.desktop</launchable>

